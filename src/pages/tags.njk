---
title: All Tags
layout: page
permalink: /tags/
---

<h1>All Tags</h1>
<p class="lead text-body-secondary">Browse games and content by topic.</p>
<div class="d-flex flex-wrap gap-2 mt-4">
    {% for tag in collections | getKeys | filterTagList | sortAlphabetically %}
	{%- set tagUrl %}/tags/{{ tag | slugify }}/{% endset %}
	<a href="{{ tagUrl }}" class="badge rounded-pill text-bg-secondary text-decoration-none fs-6 fw-normal">
		<i class="bi bi-tag me-1"></i>{{ tag }}
		<span class="badge text-bg-light ms-1">{{ collections[tag].length }}</span>
	</a>
	{%- endfor %}
</div>
