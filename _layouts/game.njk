---
layout: page
---

{{ content | safe }}

<h2>Campaigns</h2>
{%- set gameCampaigns = collections.campaigns | campaignsForGame(slug) %}
{%- if gameCampaigns.length %}
{%- for campaign in gameCampaigns %}
<div class="row mb-4 border-bottom pb-4">
  {% if campaign.data.thumbnail %}
  <div class="col-md-4">
    <a href="{{ campaign.url }}">
      <img src="{{ campaign.data.thumbnail }}" alt="{{ campaign.data.thumbnailAlt }}" class="img-fluid rounded" style="max-height: 220px; width: 100%; object-fit: cover;">
    </a>
  </div>
  <div class="col-md-8">
  {% else %}
  <div class="col-12">
  {% endif %}
    <h3><a href="{{ campaign.url }}" class="text-decoration-none">{{ campaign.data.title }}</a></h3>
    <div class="mb-2">
      {% if campaign.data.activeCampaign %}
        <span class="badge text-bg-success">Active</span>
      {% else %}
        <span class="badge text-bg-light text-dark border">Completed</span>
      {% endif %}
    </div>
    {% if campaign.data.description %}<p>{{ campaign.data.description }}</p>{% endif %}
    <a href="{{ campaign.url }}" class="btn btn-outline-secondary btn-sm">View campaign</a>
  </div>
</div>
{%- endfor %}
{% else %}
<p>No campaigns for this game yet.</p>
{%- endif %}

<h2>Battle Reports</h2>
{%- set gameBattleReports = collections.battlereports | battleReportsForGame(slug) %}
{%- if gameBattleReports.length %}
{%- for report in gameBattleReports %}
<div class="row mb-4 border-bottom pb-4">
  <div class="col-md-4">
    <a href="{{ report.url }}">
      <img src="{{ report.data.thumbnail }}" alt="{{ report.data.thumbnailAlt }}" class="img-fluid rounded" style="max-height: 220px; width: 100%; object-fit: cover;">
    </a>
  </div>
  <div class="col-md-8">
    <h3><a href="{{ report.url }}" class="text-decoration-none">{{ report.data.title }}</a></h3>
    <p class="text-muted">{{ report.date | readableDate }}</p>
    {% if report.data.description %}<p>{{ report.data.description }}</p>{% endif %}
    <a href="{{ report.url }}" class="btn btn-outline-secondary btn-sm">Read battle report</a>
  </div>
</div>
{%- endfor %}
{% else %}
<p>No battle reports for this game yet.</p>
{%- endif %}

<div class="d-flex flex-wrap gap-2 mt-3">
	{%- for tag in tags | filterTagList %}
	{%- set tagUrl %}/tags/{{ tag | slugify }}/{% endset %}
	<a href="{{ tagUrl }}" class="badge rounded-pill text-bg-secondary text-decoration-none fs-6 fw-normal">
		<i class="bi bi-tag me-1"></i>{{ tag }}
	</a>
	{%- endfor %}
</div>
